                player2_result = "Draw"
                result2_color = YELLOW

            player2_text = f"{player2} (P2)"
            player2_surf = HISTORY_FONT.render(player2_text, True, WHITE)
            result2_surf = HISTORY_FONT.render(player2_result, True, result2_color)

            SCREEN.blit(player2_surf, (x_start[0], y_offset))
            SCREEN.blit(result2_surf, (x_start[1], y_offset))
            # Time và Steps để trống cho dòng thứ 2
            SCREEN.blit(time_surf, (x_start[2], y_offset))
            SCREEN.blit(steps_surf, (x_start[3], y_offset))

            y_offset += 20

        # Thêm khoảng cách sau mỗi game
        y_offset += 10

        if y_offset > SCREEN_HEIGHT - 50:
            break

    # Nut quay lai
    esc_label = ESC_FONT.render("ESC:return", True, CHARTREUSE)
    SCREEN.blit(esc_label, (20, 550))

# ----- Vong lap chinh cua game -----
running = True
input_active = False
active_box = None
input_color_inactive = GRAY
input_color_active = CHARTREUSE  
input_box_color = input_color_inactive
if BACKGROUND_MUSIC and pygame.mixer.get_init():
    pygame.mixer.music.load(BACKGROUND_MUSIC)
    pygame.mixer.music.play(-1)
    pygame.mixer.music.set_volume(0.3)

while running:
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            delete_history()
            running = False

        elif game_states == MENU_SCREEN:
            if event.type == pygame.KEYDOWN and event.key == pygame.K_SPACE:
                game_states = SETUP_SCREEN

        elif game_states == SETUP_SCREEN:
            button_3x3, button_5x5, input_box_1, input_box_2, button_1_player, button_2_players = draw_setup_screen(
                input_box_color)

            if event.type == pygame.MOUSEBUTTONDOWN:
                if button_1_player.collidepoint(event.pos):
                    is_two_player = False
                    input_active = True
                    active_box = input_box_1
                    input_box_color = input_color_inactive
                elif button_2_players.collidepoint(event.pos):
                    is_two_player = True
                    input_active = True
                    active_box = input_box_1
                    input_box_color = input_color_inactive
                elif input_box_1.collidepoint(event.pos):
                    input_active = True
                    input_box_color = input_color_active
                    active_box = input_box_1
                elif is_two_player and input_box_2.collidepoint(event.pos):
                    input_active = True
                    input_box_color = input_color_active
                    active_box = input_box_2
                else:
                    if not (button_3x3.collidepoint(event.pos) or button_5x5.collidepoint(event.pos)):
                        input_active = False
                        input_box_color = input_color_inactive

                if player_name:
                    if button_3x3.collidepoint(event.pos) or button_5x5.collidepoint(event.pos):
                        if button_3x3.collidepoint(event.pos):
                            GRID_SIZE = 3
                            CELL_SIZE = 150
                        else:
                            GRID_SIZE = 5
                            CELL_SIZE = 100

                        GRID_START_X = (SCREEN_WIDTH - GRID_SIZE * CELL_SIZE) // 2
                        GRID_START_Y = (SCREEN_HEIGHT - GRID_SIZE * CELL_SIZE) // 2

                        if is_two_player:
                            reset_game()
                            game_states = GAME_SCREEN
                        else:
                            game_states = DIFFICULTY_SCREEN

                        input_active = False
                        input_box_color = input_color_inactive

            if event.type == pygame.KEYDOWN:
                if input_active:
                    if event.key == pygame.K_RETURN:
                        input_active = False
                        input_box_color = input_color_inactive
                    elif event.key == pygame.K_BACKSPACE:
                        if active_box == input_box_1:
                            player_name = player_name[:-1]
                        elif active_box == input_box_2:
                            player_name_2 = player_name_2[:-1]
                    else:
                        if active_box == input_box_1 and FONT_MEDIUM.size(player_name + event.unicode)[0] < input_box_1.width - 10:
                            player_name += event.unicode
                        elif active_box == input_box_2 and FONT_MEDIUM.size(player_name_2 + event.unicode)[0] < input_box_2.width - 10:
                            player_name_2 += event.unicode

        elif game_states == DIFFICULTY_SCREEN:
            button_easy, button_hard = draw_difficulty_screen()

            if event.type == pygame.MOUSEBUTTONDOWN:
                if button_easy.collidepoint(event.pos):
                    current_difficulty = "Easy"
                    reset_game()
                    game_states = GAME_SCREEN
                elif button_hard.collidepoint(event.pos):
                    current_difficulty = "Hard"
                    reset_game()
                    game_states = GAME_SCREEN
            if event.type == pygame.KEYDOWN and event.key == pygame.K_ESCAPE:
                game_states = SETUP_SCREEN


        elif game_states == GAME_SCREEN:
            if current_player == 'X' and event.type == pygame.MOUSEBUTTONDOWN:
                mouse_x, mouse_y = event.pos

                # Tinh toan o duoc click
                col = (mouse_x - GRID_START_X) // CELL_SIZE
                row = (mouse_y - GRID_START_Y) // CELL_SIZE

                if 0 <= row < GRID_SIZE and 0 <= col < GRID_SIZE and board[row][col] == '':
                    if MOVE_SOUND:
                        MOVE_SOUND.play()
                    board[row][col] = 'X'
                    move_counts += 1

                    if check_win(board, 'X'):
                        game_result = "Win"
                        if WIN_SOUND:
                            WIN_SOUND.play()
                        if is_two_player:
                            # 2 players: Player X thắng
                            save_history(player_name, player_name_2, "Win", move_counts, player_name)
                        else:
                            # 1 player: Người chơi thắng AI
                            save_history(player_name, "Computer", "Win", move_counts, player_name)
                        game_states = END_SCREEN
                    elif is_board_full(board):
                        game_result = "Draw"
                        if is_two_player:
                            save_history(player_name, player_name_2, "Draw", move_counts, "")
                        else:
                            save_history(player_name, "Computer", "Draw", move_counts, "")
                        game_states = END_SCREEN
                    else:
                        current_player = 'O'


            # Xu ly luot choi cua may

            elif current_player == 'O' and is_two_player and event.type == pygame.MOUSEBUTTONDOWN:
                mouse_x, mouse_y = event.pos
                col = (mouse_x - GRID_START_X) // CELL_SIZE
                row = (mouse_y - GRID_START_Y) // CELL_SIZE

                if 0 <= row < GRID_SIZE and 0 <= col < GRID_SIZE and board[row][col] == '':
                    if MOVE_SOUND:
                        MOVE_SOUND.play()
                    board[row][col] = 'O'
                    move_counts += 1

                    # --- LOGIC KẾT THÚC VÒNG ĐI CỦA O (2P) ---

                    if check_win(board, 'O'):
                        # Player O thắng trong chế độ 2 players
                        game_result = "Win"
                        if WIN_SOUND:
                            WIN_SOUND.play()
                        save_history(player_name, player_name_2, "Win", move_counts, player_name_2 if player_name_2 else "Player 2")
                        game_states = END_SCREEN

                    elif is_board_full(board):
                        game_result = "Draw"
                        save_history(player_name, player_name_2, "Draw", move_counts, "")
                        game_states = END_SCREEN
                    else:
                        current_player = 'X'

        elif game_states == END_SCREEN:
            if event.type == pygame.KEYDOWN:
                if event.key == pygame.K_SPACE:
                    reset_game()
                    game_states = GAME_SCREEN
                elif event.key == pygame.K_r:
                    game_states = HISTORY_SCREEN
                elif event.key == pygame.K_s:
                    reset_game()
                    game_states = SETUP_SCREEN
                elif event.key == pygame.K_d and not is_two_player:
                    game_states = DIFFICULTY_SCREEN
        elif game_states == HISTORY_SCREEN:
            if event.type == pygame.KEYDOWN and event.key == pygame.K_ESCAPE:
                game_states = END_SCREEN

    # Xu ly AI move (ngoài event loop)
    if game_states == GAME_SCREEN and current_player == 'O' and not is_two_player:
        pygame.time.wait(500)
        ai_pos = ai_smart_move(board)
        if ai_pos:
            r, c = ai_pos
            if MOVE_SOUND:
                MOVE_SOUND.play()
            board[r][c] = 'O'
            move_counts += 1

            if check_win(board, 'O'):
                if LOSE_SOUND:
                    LOSE_SOUND.play()
                game_result = 'Lose'
                save_history(player_name, "Computer", "Lose", move_counts, "Computer")
                game_states = END_SCREEN
            elif is_board_full(board):
                game_result = 'Draw'
                save_history(player_name, "Computer", "Draw", move_counts, "")
                game_states = END_SCREEN
            else:
                current_player = 'X'

    # Ve man hinh
    if game_states == MENU_SCREEN:
        draw_menu_screen()
    elif game_states == SETUP_SCREEN:
        draw_setup_screen(input_box_color)
    elif game_states == DIFFICULTY_SCREEN:
        draw_difficulty_screen()
    elif game_states == GAME_SCREEN:
        draw_game_screen(board)
    elif game_states == END_SCREEN:
        draw_end_screen()
    elif game_states == HISTORY_SCREEN:
        draw_history_screen()

    pygame.display.flip()

pygame.quit()
sys.exit()
