def save_history(player1_name, player2_name, result, steps, winner=""):
    timestamp = time.strftime("%d-%m-%Y %H:%M:%S")
    conn = sqlite3.connect(HISTORY_FILE)
    cursor = conn.cursor()
    cursor.execute('''
        INSERT INTO game_history (player1_name, player2_name, time, steps, result, winner)
        VALUES (?,?,?,?,?,?)
    ''', (player1_name, player2_name, timestamp, steps, result, winner))
    conn.commit()
    conn.close()


def load_history():
    conn = sqlite3.connect(HISTORY_FILE)
    cursor = conn.cursor()
    cursor.execute('SELECT player1_name, player2_name, time, steps, result, winner FROM game_history')
    rows = cursor.fetchall()
    conn.close()
    return rows


def delete_history():
    conn = sqlite3.connect(HISTORY_FILE)
    cursor = conn.cursor()
    cursor.execute('Delete FROM game_history')
    conn.commit()
    conn.close()
    print("All the history has been deleted")


# --- AI Logic ---
WIN_SCORE = 100000
MAX_DEPTH3X3 = 9
MAX_DEPTH5X5 = 4


def minimax(board, depth, is_maximizing_player, alpha, beta):
    # Kiem tra dieu kien dung
    if check_win(board, 'O'):
        return WIN_SCORE - depth
    if check_win(board, 'X'):
        return -WIN_SCORE + depth
    if is_board_full(board):
        return 0
    # Gioi han do sau tim kiem
    if GRID_SIZE == 5 and depth >= MAX_DEPTH5X5:
        return 0
    elif GRID_SIZE == 3 and depth >= MAX_DEPTH3X3:
        return 0
    # Tim o co trong
    empty_cells = [(r, c) for r in range(GRID_SIZE) for c in range(GRID_SIZE) if board[r][c] == '']

    # Luot cua max (AI - O)
    if is_maximizing_player:
        max_eval = -float("inf")
        for r, c in empty_cells:
            board[r][c] = 'O'
            # Goi de quy
            eval = minimax(board, depth + 1, False, alpha, beta)
            # Hoan tac nuoc di
            board[r][c] = ''

            max_eval = max(max_eval, eval)
            alpha = max(alpha, max_eval)

            # Cat tia alpha-beta
            if beta <= alpha:
                break
        return max_eval

    # Luot cua min (nguoi choi - X)
    else:
        min_eval = float('inf')
        for r, c in empty_cells:
            board[r][c] = 'X'
            # Goi de quy
            eval = minimax(board, depth + 1, True, alpha, beta)
            # Hoan tac nuoc di
            board[r][c] = ''

            min_eval = min(min_eval, eval)
            beta = min(beta, min_eval)

            # Cat tia alpha-beta
            if beta <= alpha:
                break
        return min_eval


def ai_move_random(board):
    empty_cells = [(r, c) for r in range(GRID_SIZE) for c in range(GRID_SIZE) if board[r][c] == '']
    if empty_cells:
        r, c = random.choice(empty_cells)
        return r, c
    return None


def ai_smart_move_minimax(board):
    best_score = -float('inf')
    best_move = None

    empty_cells = [(r, c) for r in range(GRID_SIZE) for c in range(GRID_SIZE) if board[r][c] == '']
    # Neu khong con o trong , tra ve none
    if not empty_cells:
        return None

    # Duyet qua tat ca nuoc di co the va tim nuoc di tot nhat
    for r, c in empty_cells:
        # Thuc hien nuoc di (AI - O)
        board[r][c] = 'O'
        # Goi minimax (luot tiep theo la min)
        # bat dau voi alpha = -inf va beta = +inf
        score = minimax(board, 0, False, -float('inf'), float('inf'))

        # Hoan tac nuoc di
        board[r][c] = ''
        # Cap nhat nuoc di tot nhat
        if score > best_score:
            best_score = score
            best_move = r, c
    # Tra ve nuoc di tot nhat
    return best_move


def ai_smart_move(board):
    global current_difficulty
    if current_difficulty == 'Easy':
        return ai_move_random(board)
    else:
        return ai_smart_move_minimax(board)


